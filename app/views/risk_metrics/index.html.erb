<!-- app/views/risk_metrics/index.html.erb -->

<h2>VaR & CVaR Chart <% if @symbol %>for <%= @symbol %><% end %></h2>

<%= form_tag risk_metrics_path, method: :get, class: "form-inline", style: "margin-bottom: 20px;" do %>
  <label>Symbol:</label>
  <%= select_tag :symbol, options_for_select(@all_symbols, @symbol), include_blank: "All Symbols" %>

  <label style="margin-left: 20px;">From:</label>
  <%= date_field_tag :start_date, @start_date %>

  <label style="margin-left: 20px;">To:</label>
  <%= date_field_tag :end_date, @end_date %>

  <%= submit_tag "Filter", style: "margin-left: 20px;" %>
<% end %>

<canvas id="riskChart" width="1000" height="400"></canvas>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const ctx = document.getElementById("riskChart").getContext("2d");

  const chart = new Chart(ctx, {
    type: "line",
    data: {
      labels: <%= raw @dates.to_json %>,
      datasets: [
        {
          label: "VaR",
          data: <%= raw @vars.to_json %>,
          borderColor: "rgba(255, 0, 0, 1)", // Red
          backgroundColor: "rgba(255, 0, 0, 0.1)",
          fill: false,
        },
        {
          label: "CVaR",
          data: <%= raw @cvars.to_json %>,
          borderColor: "rgba(0, 128, 0, 1)",       // Green border
          backgroundColor: "rgba(0, 128, 0, 0.1)", // Light green fill
          fill: false,
        },
      ],
    },
    options: {
      responsive: true,
      scales: {
        x: {
          title: { display: true, text: "Date" }
        },
        y: {
          title: { display: true, text: "Value at Risk" }
        }
      }
    }
  });
</script>


<h3>Debug Data</h3>
<table class="table table-bordered table-condensed">
  <thead>
    <tr>
      <th>Symbol</th>
      <th>VaR</th>
      <th>CVaR</th>
      <th>Calculated At</th>
    </tr>
  </thead>
  <tbody>
    <% @debug_data.each do |symbol, var, cvar, date| %>
      <tr>
        <td><%= symbol %></td>
        <td><%= var %></td>
        <td><%= cvar %></td>
        <td><%= date.strftime("%Y-%m-%d %H:%M:%S") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
